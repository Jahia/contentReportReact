<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">
    <bean parent="jobSchedulingBean">
        <property name="jobDetail">
            <bean class="org.springframework.scheduling.quartz.JobDetailBean">
                <property name="name" value="ContentReportsUsersGroupsJob"/>
                <property name="jobClass" value="org.jahia.modules.contentreports.service.ReportUsersAndGroupsBackgroundJob"/>
                <property name="group" value="Maintenance"/>
                <property name="jobDataAsMap">
                    <map>
                        <entry key="csvRootPath" value="${jahia.contentReports.usersGroups.job.csvRootPath:/sites/systemsite/files}"/>
                        <entry key="userPropertiesToExport" value="${jahia.contentReports.usersGroups.job.userPropertiesToExport:j:firstName,j:lastName}"/>
                    </map>
                </property>
                <property name="description" value="Create CSV files with all users and their groups for all websites"/>
            </bean>
        </property>
        <property name="trigger">
            <bean class="org.quartz.CronTrigger">
                <property name="name" value="ContentReportsUsersGroupsJobTrigger"/>
                <property name="cronExpression" value="${jahia.contentReports.usersGroups.job.cronExpression:0 30 1 * * ?}"/>
            </bean>
        </property>
    </bean>
</beans>
